# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/budgeting_tool
DB_HOST=localhost
DB_PORT=5432
DB_NAME=budgeting_tool
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Authentication
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRY=7d

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@budgettool.com

# Email Development (for testing)
ETHEREAL_USER=your-ethereal-test-email
ETHEREAL_PASSWORD=your-ethereal-password

# App URL (for email links)
APP_URL=http://localhost:5173

# Bank Integration - Plaid (Optional)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=development

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
